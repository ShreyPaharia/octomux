# octomux — environment template.
# Copy to .env in the directory you launch octomux from, fill in, and start:
#   octomux start
# The server auto-loads .env at boot (real env vars still win over .env).

# ─── Telegram gateway (opt-in) ───────────────────────────────────────────────
# Talk to the octomux conductor over a Telegram DM. Leave the token unset to
# keep the gateway disabled. See docs/gateway-setup.md.

# Bot token from @BotFather (https://t.me/botfather → /newbot).
OCTOMUX_GATEWAY_TELEGRAM_TOKEN=

# CSV of ALLOWED numeric Telegram user ids (default-deny: empty = nobody).
# Find yours via @userinfobot. This is message.from.id, not your @handle.
OCTOMUX_GATEWAY_TELEGRAM_ALLOW=

# Optional: repo the assistant's conductor operates from, shared by every
# gateway channel (Telegram, Slack, ...). Defaults to cwd.
OCTOMUX_GATEWAY_CWD=

# ─── Slack gateway (opt-in) ──────────────────────────────────────────────────
# Talk to the octomux conductor over a Slack DM. Uses Socket Mode (an outbound
# websocket) — no public webhook URL, no ngrok, and no signing secret (that's
# only for the HTTP Events API, which this doesn't use). Leave the tokens
# unset to keep the gateway disabled. See server/gateway/README.md.

# Bot token from OAuth & Permissions, starts with xoxb-.
OCTOMUX_GATEWAY_SLACK_BOT_TOKEN=

# App-level token from Basic Information → App-Level Tokens (connections:write
# scope), starts with xapp-. Used to open the Socket Mode connection.
OCTOMUX_GATEWAY_SLACK_APP_TOKEN=

# CSV of ALLOWED Slack user ids (default-deny: empty = nobody).
# Find yours via your Slack profile → "Copy member ID". This is a user id
# like U01ABCDEF, not your @handle.
OCTOMUX_GATEWAY_SLACK_ALLOW=
